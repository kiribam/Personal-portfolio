---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'About me · Portfolio';
const description =
	'Background, interests, and how to connect with Kiri Bamrungpong.';
---

<BaseLayout {title} {description}>
	<section class="prose">
		<h1>About me</h1>
		<p>
			I am a developer focused on building clear, reliable software. This portfolio is built with
			Astro as a static site so it stays fast, inexpensive to host, and straightforward to extend.
		</p>
	</section>

	<section class="section-block" aria-labelledby="skills-heading">
		<h2 id="skills-heading" class="section-heading">Skills &amp; tools</h2>
		<p class="section-intro">Edit this list to match your résumé or LinkedIn.</p>
		<ul class="tag-list tag-list-inline" aria-label="Skills">
			<li>TypeScript</li>
			<li>Web platform</li>
			<li>Data &amp; APIs</li>
			<li>Cloud (GCP)</li>
		</ul>
	</section>

	<section class="section-block" aria-labelledby="contact-heading">
		<h2 id="contact-heading" class="section-heading">Contact</h2>
		<p class="section-intro">
			<a href="https://github.com/kiribam" rel="noopener noreferrer" target="_blank">GitHub</a>
			<span class="link-sep">·</span>
			<span>Add email or LinkedIn in this file when you are ready.</span>
		</p>
	</section>
</BaseLayout>
