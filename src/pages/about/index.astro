---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'About me · Portfolio';
const description =
	'Background, interests, and how to connect with Kiri Bamrungpong.';
---

<BaseLayout {title} {description}>
	<section class="prose">
		<h1>About me</h1>
		<p>
			I am a developer focused on building clear, reliable software. This page is a placeholder you
			can extend with your story: education, experience, tools you enjoy, and what you are looking
			for next.
		</p>
		<h2>Contact</h2>
		<p>Add your email, LinkedIn, or GitHub links here when you are ready.</p>
	</section>
</BaseLayout>
