---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectList from '../components/ProjectList.astro';
import { getFeaturedProjects } from '../data/projects';

const title = 'Home · Portfolio';
const description =
	'Personal portfolio: projects, background, and selected work by Kiri Bamrungpong.';
const featured = getFeaturedProjects();
---

<BaseLayout {title} {description}>
	<section class="hero" aria-labelledby="hero-heading">
		<h1 id="hero-heading" class="hero-title">Software that stays clear under pressure.</h1>
		<p class="hero-lede">
			I am Kiri Bamrungpong. This site collects projects I ship—web work, data and ML, and open
			source—plus a bit about me. Everything here is static, fast, and easy to host on GCP or
			elsewhere.
		</p>
		<p class="hero-actions">
			<a class="button" href="/projects/">Browse projects</a>
			<a class="button button-ghost" href="/about/">About me</a>
		</p>
	</section>

	<section class="section-block" aria-labelledby="featured-heading">
		<h2 id="featured-heading" class="section-heading">Featured work</h2>
		<p class="section-intro">
			Highlights from <a href="/projects/">the project list</a>. Edit <code>src/data/projects.ts</code>{' '}
			to feature what you want on the home page.
		</p>
		<ProjectList projects={featured} emptyMessage="No featured projects yet. Mark items with featured: true in src/data/projects.ts." />
	</section>
</BaseLayout>
