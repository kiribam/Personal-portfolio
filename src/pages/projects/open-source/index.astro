---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Open source · Projects';
const description =
	'Open source libraries and contributions—placeholder for your portfolio.';
---

<BaseLayout {title} {description}>
	<section class="prose">
		<h1>Open source</h1>
		<p>
			Highlight repositories you maintain or meaningfully contribute to. Mention stars, adoption,
			or notable issues you helped close.
		</p>
		<p><a href="/projects/">← Back to projects overview</a></p>
	</section>
</BaseLayout>
