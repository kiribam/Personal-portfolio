---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Web apps · Projects';
const description =
	'Web applications and front-end work—placeholder content for your portfolio.';
---

<BaseLayout {title} {description}>
	<section class="prose">
		<h1>Web apps</h1>
		<p>
			Describe SPAs, dashboards, or full-stack apps here. For each entry, consider: problem, stack,
			your role, outcome, and a link to the live site or repo.
		</p>
		<p><a href="/projects/">← Back to projects overview</a></p>
	</section>
</BaseLayout>
